# Copy this to .env and fill in your values. Never commit .env.

# LLM provider: "anthropic" | "groq" | "ollama"
LLM_PROVIDER=groq

# Groq — FREE tier, no credit card needed. Get key at console.groq.com
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (paid — best quality)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (fully local, no internet or API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Qdrant — local Docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=docqa

# Qdrant Cloud (leave blank when using local Docker)
# Get these from cloud.qdrant.io → your cluster → API Keys
QDRANT_URL=
QDRANT_API_KEY=

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-base
USE_RERANKER=true

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# Chunking
CHUNK_TOKENS=500
CHUNK_OVERLAP=50

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Evaluation: limit golden-set size in CI to control cost (0 = all)
EVAL_SAMPLE_SIZE=10
